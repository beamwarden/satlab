[Unit]
Description=satlab Sense HAT agent (beamrider-0004)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=jeb
WorkingDirectory=/home/jeb/satlab/sense-agent
EnvironmentFile=/home/jeb/satlab/.env
ExecStart=/usr/bin/python3 /home/jeb/satlab/sense-agent/main.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
