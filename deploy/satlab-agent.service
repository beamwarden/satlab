[Unit]
Description=satlab Beamrider agent (beamrider-0003)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=jeb
WorkingDirectory=/home/jeb/satlab/agent
EnvironmentFile=/home/jeb/satlab/.env
ExecStart=/usr/bin/python3 /home/jeb/satlab/agent/main.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
